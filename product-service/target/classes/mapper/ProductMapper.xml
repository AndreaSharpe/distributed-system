<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.productservice.mapper.ProductMapper">
    <select id="findAll" resultType="com.example.productservice.entity.Product">
        SELECT * FROM product
    </select>
    <select id="findById" resultType="com.example.productservice.entity.Product">
        SELECT * FROM product WHERE id = #{id}
    </select>
    <insert id="insertProduct" parameterType="com.example.productservice.entity.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, price, stock, description, created_at)
        VALUES (#{name}, #{price}, #{stock}, #{description}, #{createdAt})
    </insert>
    <update id="updateProduct" parameterType="com.example.productservice.entity.Product">
        UPDATE product SET name = #{name}, price = #{price}, stock = #{stock}, description = #{description}
        WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM product WHERE id = #{id}
    </delete>
</mapper>
